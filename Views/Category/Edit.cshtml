@model RestaurantFoodOrderingAdmin.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-edit me-2"></i>Edit Category
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <!-- Edit Form Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-body">
                <form method="post" asp-action="Edit">
                    <input type="hidden" asp-for="CategoryId" />
                    <input type="hidden" asp-for="CreatedDate" />

                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label">Category Name</label>
                        <input asp-for="CategoryName" class="form-control" placeholder="Enter category name" />
                        <span asp-validation-for="CategoryName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" 
                                  placeholder="Enter category description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Food Type</label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input type="radio" asp-for="IsVeg" value="true" class="form-check-input" id="vegOption" />
                                <label class="form-check-label d-flex align-items-center gap-2" for="vegOption">
                                    <span class="veg-icon" style="display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border: 2px solid #6A994E; border-radius: 3px;">
                                        <span style="width: 10px; height: 10px; background-color: #6A994E; border-radius: 50%;"></span>
                                    </span>
                                    Vegetarian
                                </label>
                            </div>
                            <div class="form-check">
                                <input type="radio" asp-for="IsVeg" value="false" class="form-check-input" id="nonVegOption" />
                                <label class="form-check-label d-flex align-items-center gap-2" for="nonVegOption">
                                    <span class="non-veg-icon" style="display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border: 2px solid #C1121F; border-radius: 3px;">
                                        <span style="width: 10px; height: 10px; background-color: #C1121F; border-radius: 50%;"></span>
                                    </span>
                                    Non-Vegetarian
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label">Image URL</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <small class="form-text text-muted">Enter the full URL of the category image</small>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label">Current Image</label>
                            <div>
                                <img src="@Model.ImageUrl" alt="Category Image" class="img-preview">
                            </div>
                        </div>
                    }

                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">
                            Active
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Update Category
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
