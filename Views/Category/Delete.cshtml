@model RestaurantFoodOrderingAdmin.Models.Category
@{
    ViewData["Title"] = "Delete Category";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>Delete Category
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-danger">
        <h5 class="alert-heading">
            <i class="fas fa-exclamation-circle me-2"></i>Warning!
        </h5>
        <p class="mb-0">Are you sure you want to delete this category? This action cannot be undone.</p>
    </div>

    <!-- Category Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Category to be Deleted</h5>
                </div>
                <div class="card-body">

                <dl class="row">
                    <dt class="col-sm-4">Category ID:</dt>
                    <dd class="col-sm-8">@Model.CategoryId</dd>

                    <dt class="col-sm-4">Category Name:</dt>
                    <dd class="col-sm-8">@Model.CategoryName</dd>

                    <dt class="col-sm-4">Description:</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created Date:</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("dd MMM yyyy")</dd>
                </dl>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-3">
                        <strong>Image:</strong><br>
                        <img src="@Model.ImageUrl" alt="Category Image" class="img-preview">
                    </div>
                }

                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Form -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card mt-4 border-danger">
                <div class="card-body">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="CategoryId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete This Category
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>No, Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
