@model IEnumerable<RestaurantFoodOrderingAdmin.Models.Customer>
@{
    ViewData["Title"] = "Manage Customers";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-users me-2"></i>Manage Customers
        </h2>
        <div class="d-flex gap-3">
            <input type="text" id="searchInput" class="form-control" placeholder="Search customers..." 
                   style="width: 250px;" onkeyup="filterCustomers()">
            <select id="statusFilter" class="form-select" style="width: 150px;" onchange="filterCustomers()">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Customers Table -->
    <div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover" id="customersTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th>Joined Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td>@customer.CustomerId</td>
                                <td>@customer.FullName</td>
                                <td>@customer.Email</td>
                                <td>@customer.Phone</td>
                                <td>
                                    @if (customer.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>@customer.CreatedDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = customer.CustomerId })" 
                                       class="btn btn-sm btn-info text-white" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <form method="post" asp-action="ToggleStatus" asp-route-id="@customer.CustomerId" 
                                          style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-warning" 
                                                title="@(customer.IsActive ? "Deactivate" : "Activate")">
                                            <i class="fas fa-power-off"></i>
                                        </button>
                                    </form>
                                    <a href="@Url.Action("Delete", new { id = customer.CustomerId })" 
                                       class="btn btn-sm btn-danger" title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users fa-5x text-muted mb-3"></i>
                <h4>No Customers Found</h4>
                <p class="text-muted">Customer information will appear here once they register.</p>
            </div>
        }
    </div>
    </div>
</div>

@section Scripts {
<script>
    function filterCustomers() {
        var searchInput = document.getElementById('searchInput').value.toLowerCase();
        var statusFilter = document.getElementById('statusFilter').value.toLowerCase();
        var table = document.getElementById('customersTable');
        var rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
        
        for (var i = 0; i < rows.length; i++) {
            var nameCell = rows[i].getElementsByTagName('td')[1]; // Name column (index 1)
            var emailCell = rows[i].getElementsByTagName('td')[2]; // Email column (index 2)
            var statusCell = rows[i].getElementsByTagName('td')[4]; // Status column (index 4)
            
            var showRow = true;
            
            // Search filter (search by name or email)
            if (searchInput !== '') {
                var nameText = nameCell ? (nameCell.textContent || nameCell.innerText).toLowerCase() : '';
                var emailText = emailCell ? (emailCell.textContent || emailCell.innerText).toLowerCase() : '';
                if (!nameText.includes(searchInput) && !emailText.includes(searchInput)) {
                    showRow = false;
                }
            }
            
            // Status filter
            if (statusCell && statusFilter !== '' && showRow) {
                var statusText = statusCell.textContent || statusCell.innerText;
                if (!statusText.toLowerCase().includes(statusFilter)) {
                    showRow = false;
                }
            }
            
            rows[i].style.display = showRow ? '' : 'none';
        }
    }
</script>
}
