@model IEnumerable<RestaurantFoodOrderingAdmin.Models.Coupon>
@{
    ViewData["Title"] = "Coupons & Discounts Management";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-ticket-alt me-2"></i>Coupons & Discounts
        </h2>
        <div>
            <a href="@Url.Action("Assign")" class="btn btn-info me-2">
                <i class="fas fa-user-tag me-1"></i>Assign Coupons
            </a>
            <a href="@Url.Action("Statistics")" class="btn btn-secondary me-2">
                <i class="fas fa-chart-bar me-1"></i>Statistics
            </a>
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Create New Coupon
            </a>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card stats-card bg-primary text-white">
                <div class="card-body">
                    <h6>Total Coupons</h6>
                    <h3>@ViewBag.TotalCoupons</h3>
                    <i class="fas fa-ticket-alt stats-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card stats-card bg-success text-white">
                <div class="card-body">
                    <h6>Active Coupons</h6>
                    <h3>@ViewBag.ActiveCoupons</h3>
                    <i class="fas fa-check-circle stats-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card stats-card bg-warning text-white">
                <div class="card-body">
                    <h6>Expired</h6>
                    <h3>@ViewBag.ExpiredCoupons</h3>
                    <i class="fas fa-clock stats-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-info text-white">
                <div class="card-body">
                    <h6>Total Assignments</h6>
                    <h3>@ViewBag.TotalAssignments</h3>
                    <i class="fas fa-users stats-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-dark text-white">
                <div class="card-body">
                    <h6>Used Coupons</h6>
                    <h3>@ViewBag.UsedCoupons</h3>
                    <i class="fas fa-shopping-cart stats-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="searchTerm" class="form-control"
                           placeholder="Search by code or description..."
                           value="@ViewBag.SearchTerm">
                </div>
                <div class="col-md-4">
                    <select name="filterStatus" class="form-select">
                        <option value="all" selected="@(ViewBag.FilterStatus == "all")">All Coupons</option>
                        <option value="active" selected="@(ViewBag.FilterStatus == "active")">Active Only</option>
                        <option value="expired" selected="@(ViewBag.FilterStatus == "expired")">Expired</option>
                        <option value="inactive" selected="@(ViewBag.FilterStatus == "inactive")">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Search
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Coupons Table -->
    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Description</th>
                                <th>Type</th>
                                <th>Discount</th>
                                <th>Min Order</th>
                                <th>Expiry Date</th>
                                <th>Usage Limit</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var coupon in Model)
                            {
                                <tr>
                                    <td>
                                        <strong class="text-primary">@coupon.CouponCode</strong>
                                    </td>
                                    <td>@coupon.Description</td>
                                    <td>
                                        @if (coupon.DiscountType == "Percentage")
                                        {
                                            <span class="badge bg-info">Percentage</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Fixed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (coupon.DiscountType == "Percentage")
                                        {
                                            <text>@coupon.DiscountValue%</text>
                                            @if (coupon.MaxDiscountAmount.HasValue)
                                            {
                                                <small class="text-muted">(Max: ₹@coupon.MaxDiscountAmount)</small>
                                            }
                                        }
                                        else
                                        {
                                            <text>₹@coupon.DiscountValue</text>
                                        }
                                    </td>
                                    <td>₹@coupon.MinimumOrderAmount</td>
                                    <td>
                                        @coupon.ExpiryDate.ToString("dd MMM yyyy")
                                        @if (coupon.ExpiryDate < DateTime.Now)
                                        {
                                            <br>
                                
                                            <span class="badge bg-danger">Expired</span>
                                        }
                                    </td>
                                    <td>@coupon.UsageLimit</td>
                                    <td>
                                        <button class="btn btn-sm toggle-status-btn"
                                                data-id="@coupon.CouponId"
                                                data-status="@coupon.IsActive">
                                            @if (coupon.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </button>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="@Url.Action("Assignments", new { id = coupon.CouponId })"
                                               class="btn btn-sm btn-info" title="View Assignments">
                                                <i class="fas fa-users"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = coupon.CouponId })"
                                               class="btn btn-sm btn-warning" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", new { id = coupon.CouponId })"
                                               class="btn btn-sm btn-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                    <h5>No coupons found</h5>
                    <p class="text-muted">Create your first coupon to get started</p>
                    <a href="@Url.Action("Create")" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Create Coupon
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .stats-card {
        border-radius: 10px;
        border: none;
        position: relative;
        overflow: hidden;
    }

        .stats-card .card-body {
            padding: 20px;
            position: relative;
            z-index: 1;
        }

        .stats-card h6 {
            font-size: 0.85rem;
            margin-bottom: 10px;
            opacity: 0.9;
        }

        .stats-card h3 {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 0;
        }

    .stats-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 3rem;
        opacity: 0.2;
    }

    .toggle-status-btn {
        border: none;
        background: transparent;
        padding: 0;
        cursor: pointer;
    }

        .toggle-status-btn:hover .badge {
            opacity: 0.8;
        }
</style>

<script>
    // Toggle coupon status
    document.querySelectorAll('.toggle-status-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const couponId = this.dataset.id;

            if (confirm('Are you sure you want to toggle this coupon status?')) {
                fetch('/Coupon/ToggleStatus/' + couponId, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    alert('Error toggling status');
                });
            }
        });
    });
</script>
