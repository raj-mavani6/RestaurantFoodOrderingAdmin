<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" />
    <link rel="stylesheet" href="~/css/chart.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (Context.Session.GetInt32("AdminId") != null)
    {
        <div class="wrapper">
            <!-- Sidebar -->
            <nav id="sidebar" class="sidebar">
                <div class="sidebar-header">
                    <h3><i class="fas fa-utensils me-2"></i>Tasty Bites</h3>
                    <p class="sidebar-subtitle small mb-0">Admin Panel</p>
                </div>

                <ul class="list-unstyled components">
                    <li>
                        <a href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home me-2"></i>Dashboard
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Category")">
                            <i class="fas fa-th-large me-2"></i>Categories
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "FoodItem")">
                            <i class="fas fa-utensils me-2"></i>Food Items
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Combo")">
                            <i class="fas fa-box-open me-2"></i>Combo Offers
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Order")">
                            <i class="fas fa-receipt me-2"></i>Orders
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Customer")">
                            <i class="fas fa-users me-2"></i>Customers
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Review")">
                            <i class="fas fa-star me-2"></i>Reviews & Ratings
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Coupon")">
                            <i class="fas fa-ticket-alt me-2"></i>Coupons & Discounts
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "PaymentTransaction")">
                            <i class="fas fa-credit-card me-2"></i>Payment Transactions
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "Report")">
                            <i class="fas fa-chart-bar me-2"></i>Reports & Analytics
                        </a>
                    </li>
                </ul>

                <div class="sidebar-footer">
                    <div class="admin-info">
                        <i class="fas fa-user-shield me-2"></i>
                        <span>@Context.Session.GetString("AdminName")</span>
                    </div>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger btn-sm mt-2 w-100">
                        <i class="fas fa-sign-out-alt me-1"></i>Logout
                    </a>
                </div>
            </nav>

            <!-- Page Content -->
            <div id="content">
                <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
                    <div class="container-fluid">
                        <button type="button" id="sidebarCollapse" class="btn btn-primary-custom">
                            <i class="fas fa-bars"></i>
                        </button>
                        <span class="ms-3 fw-bold">@ViewData["Title"]</span>
                    </div>
                </nav>

                <div class="container-fluid">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @RenderBody()
                </div>

                <!-- Footer -->
                <footer class="admin-footer mt-auto py-3 bg-white border-top">
                    <div class="container-fluid">
                        <div class="row align-items-center">
                            <div class="col-md-6 text-center text-md-start">
                                <p class="mb-0 text-muted">
                                    <i class="fas fa-utensils me-2"></i>
                                    <strong>Tasty Bites</strong> Admin Panel &copy; @DateTime.Now.Year
                                </p>
                            </div>
                            <div class="col-md-6 text-center text-md-end">
                                <p class="mb-0 text-muted">
                                    <i class="fas fa-code me-1"></i>
                                    Developed with <!-- <i class="fas fa-heart text-danger mx-1"></i> --> Raj Mavnai.
                                </p>
                            </div>
                        </div>
                    </div>
                </footer>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/admin.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
