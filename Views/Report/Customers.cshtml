@model List<RestaurantFoodOrderingAdmin.Models.Customer>
@{
    ViewData["Title"] = "Customer Reports";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-users me-2"></i>Customer Reports
                    </h2>
                    <p class="text-muted">Customer analytics and behavior insights</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                    <a href="@Url.Action("ExportCustomersCSV")" class="btn btn-info">
                        <i class="fas fa-download me-1"></i>Export CSV
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Customers</h6>
                    <h3 class="mb-0">@ViewBag.TotalCustomers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Active Customers</h6>
                    <h3 class="mb-0">@ViewBag.ActiveCustomers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">New This Month</h6>
                    <h3 class="mb-0">@ViewBag.NewCustomersThisMonth</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Activity Section -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="mb-2">
                        <i class="fas fa-user-clock fa-2x text-warning"></i>
                    </div>
                    <h6 class="text-muted">Inactive Customers</h6>
                    <h3 class="mb-0 text-warning">@ViewBag.InactiveCustomers</h3>
                    <small class="text-muted">No orders placed</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="mb-2">
                        <i class="fas fa-redo fa-2x text-success"></i>
                    </div>
                    <h6 class="text-muted">Repeat Customers</h6>
                    <h3 class="mb-0 text-success">@ViewBag.RepeatCustomers</h3>
                    <small class="text-muted">2+ orders</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="mb-2">
                        <i class="fas fa-user-plus fa-2x text-info"></i>
                    </div>
                    <h6 class="text-muted">New This Week</h6>
                    <h3 class="mb-0 text-info">@ViewBag.NewCustomersThisWeek</h3>
                    <small class="text-muted">Last 7 days</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="mb-2">
                        <i class="fas fa-rupee-sign fa-2x text-primary"></i>
                    </div>
                    <h6 class="text-muted">Avg Spend/Customer</h6>
                    <h3 class="mb-0 text-primary">₹@ViewBag.AvgSpendPerCustomer.ToString("N2")</h3>
                    <small class="text-muted">All time</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Customer Reports Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card chart-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-user-plus me-2"></i>Customer Registration Trend</h5>
                    <div class="chart-filters">
                        <button class="filter-btn" data-filter="daily" onclick="loadCustomerChart('daily')">Daily</button>
                        <button class="filter-btn" data-filter="weekly" onclick="loadCustomerChart('weekly')">Weekly</button>
                        <button class="filter-btn active" data-filter="monthly" onclick="loadCustomerChart('monthly')">Monthly</button>
                        <button class="filter-btn" data-filter="yearly" onclick="loadCustomerChart('yearly')">Yearly</button>
                        <button class="filter-btn" data-filter="all" onclick="loadCustomerChart('all')">All Time</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="customer-chart-container" style="position: relative; height: 350px;">
                        <canvas id="customerChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Customer Details</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Registration Date</th>
                                <th>Total Orders</th>
                                <th>Total Spent</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in Model)
                            {
                                var customerOrders = (Dictionary<int, List<RestaurantFoodOrderingAdmin.Models.Order>>)ViewBag.CustomerOrders;
                                var orders = customerOrders.ContainsKey(customer.CustomerId) ? customerOrders[customer.CustomerId] : new List<RestaurantFoodOrderingAdmin.Models.Order>();
                                var totalOrders = orders.Count;
                                var totalSpent = orders.Sum(o => o.TotalAmount);
                                var isActive = totalOrders > 0;
                                <tr>
                                    <td><strong>#@customer.CustomerId</strong></td>
                                    <td>@customer.FullName</td>
                                    <td>@customer.Email</td>
                                    <td>@customer.Phone</td>
                                    <td>@customer.CreatedDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (totalOrders > 0)
                                        {
                                            <span class="badge bg-primary">@totalOrders</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">0</span>
                                        }
                                    </td>
                                    <td><strong>₹@totalSpent.ToString("F2")</strong></td>
                                    <td>
                                        @if (isActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No customer data available.
                </div>
            }
        </div>
    </div>

    <!-- Customer Insights -->
    @if (Model != null && Model.Any())
    {
        var customerOrders = (Dictionary<int, List<RestaurantFoodOrderingAdmin.Models.Order>>)ViewBag.CustomerOrders;
        var topCustomer = Model.OrderByDescending(c =>
        {
            var orders = customerOrders.ContainsKey(c.CustomerId) ? customerOrders[c.CustomerId] : new List<RestaurantFoodOrderingAdmin.Models.Order>();
            return orders.Sum(o => o.TotalAmount);
        }).FirstOrDefault();
        var avgOrdersPerCustomer = Model.Average(c =>
        {
            var orders = customerOrders.ContainsKey(c.CustomerId) ? customerOrders[c.CustomerId] : new List<RestaurantFoodOrderingAdmin.Models.Order>();
            return orders.Count;
        });
        var avgSpendPerCustomer = Model.Average(c =>
        {
            var orders = customerOrders.ContainsKey(c.CustomerId) ? customerOrders[c.CustomerId] : new List<RestaurantFoodOrderingAdmin.Models.Order>();
            return orders.Sum(o => o.TotalAmount);
        });

        <div class="card mt-4">
            <div class="card-header" style="background-color: #343a40;">
                <h5 class="mb-0 text-white">
                    <i class="fas fa-chart-pie me-2 text-white"></i>Customer Insights
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h6 class="text-muted">Top Customer</h6>
                        @if (topCustomer != null)
                        {
                            var topCustomerOrders = customerOrders.ContainsKey(topCustomer.CustomerId) ? customerOrders[topCustomer.CustomerId] : new List<RestaurantFoodOrderingAdmin.Models.Order>();
                            var topCustomerSpent = topCustomerOrders.Sum(o => o.TotalAmount);
                            <p class="mb-0"><strong>@topCustomer.FullName</strong></p>
                            <small class="text-muted">Total Spent: ₹@topCustomerSpent.ToString("F2")</small>
                        }
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Avg Orders Per Customer</h6>
                        <p class="mb-0"><strong>@avgOrdersPerCustomer.ToString("F1")</strong></p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-muted">Avg Spend Per Customer</h6>
                        <p class="mb-0"><strong>₹@avgSpendPerCustomer.ToString("F2")</strong></p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/chart.js"></script>
<script>
    // Initialize chart after scripts are loaded
    if (document.getElementById('customerChart')) {
        loadCustomerChart('monthly');
    }
</script>
}
