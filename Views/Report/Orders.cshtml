@model List<RestaurantFoodOrderingAdmin.Models.Order>
@{
    ViewData["Title"] = "Order Reports";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-receipt me-2"></i>Order Reports
                    </h2>
                    <p class="text-muted">Track orders by status and performance</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                    <a href="@Url.Action("ExportOrdersCSV")" class="btn btn-primary">
                        <i class="fas fa-download me-1"></i>Export CSV
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="btn-group" role="group">
                <a href="@Url.Action("Orders")" class="btn @(string.IsNullOrEmpty(Context.Request.Query["status"]) ? "btn-primary" : "btn-outline-primary")">
                    <i class="fas fa-list me-1"></i>All Orders
                </a>
                <a href="@Url.Action("Orders", new { status = "Pending" })" class="btn @(Context.Request.Query["status"] == "Pending" ? "btn-warning" : "btn-outline-warning")">
                    <i class="fas fa-clock me-1"></i>Pending
                </a>
                <a href="@Url.Action("Orders", new { status = "Processing" })" class="btn @(Context.Request.Query["status"] == "Processing" ? "btn-info" : "btn-outline-info")">
                    <i class="fas fa-spinner me-1"></i>Processing
                </a>
                <a href="@Url.Action("Orders", new { status = "Delivered" })" class="btn @(Context.Request.Query["status"] == "Delivered" ? "btn-success" : "btn-outline-success")">
                    <i class="fas fa-check me-1"></i>Delivered
                </a>
                <a href="@Url.Action("Orders", new { status = "Cancelled" })" class="btn @(Context.Request.Query["status"] == "Cancelled" ? "btn-danger" : "btn-outline-danger")">
                    <i class="fas fa-times me-1"></i>Cancelled
                </a>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Total Orders</h6>
                    <h3 class="mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Pending Orders</h6>
                    <h3 class="mb-0 text-warning">@ViewBag.PendingOrders</h3>
                </div>
            </div>
        </div>
        <div class="col mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Completed Orders</h6>
                    <h3 class="mb-0 text-success">@ViewBag.CompletedOrders</h3>
                </div>
            </div>
        </div>
        <div class="col mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="text-muted">Cancelled Orders</h6>
                    <h3 class="mb-0 text-danger">@ViewBag.CancelledOrders</h3>
                </div>
            </div>
        </div>
        <div class="col mb-3">
            <div class="card h-100 bg-primary text-white">
                <div class="card-body">
                    <h6 class="text-white-50">Avg Order Value</h6>
                    <h3 class="mb-0">₹@ViewBag.AverageOrderValue.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Reports Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card chart-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Order Trend</h5>
                    <div class="chart-filters">
                        <button class="filter-btn" data-filter="daily" onclick="loadOrderChart('daily')">Daily</button>
                        <button class="filter-btn" data-filter="weekly" onclick="loadOrderChart('weekly')">Weekly</button>
                        <button class="filter-btn active" data-filter="monthly" onclick="loadOrderChart('monthly')">Monthly</button>
                        <button class="filter-btn" data-filter="yearly" onclick="loadOrderChart('yearly')">Yearly</button>
                        <button class="filter-btn" data-filter="all" onclick="loadOrderChart('all')">All Time</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="order-chart-container" style="position: relative; height: 350px;">
                        <canvas id="orderChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Order Details</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Phone</th>
                                <th>Items</th>
                                <th>Amount</th>
                                <th>Payment</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><strong>#@order.OrderId</strong></td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@(order.Customer?.FullName ?? "N/A")</td>
                                    <td>@order.ContactPhone</td>
                                    <td>@(order.OrderItems?.Count ?? 0)</td>
                                    <td><strong>₹@order.TotalAmount.ToString("F2")</strong></td>
                                    <td>
                                        <small class="text-muted">@order.PaymentMethod</small>
                                    </td>
                                    <td>
                                        @if (order.Status == "Delivered")
                                        {
                                            <span class="badge bg-success">@order.Status</span>
                                        }
                                        else if (order.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">@order.Status</span>
                                        }
                                        else if (order.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">@order.Status</span>
                                        }
                                        else if (order.Status == "Processing")
                                        {
                                            <span class="badge bg-info">@order.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@order.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No orders found with the selected status.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/chart.js"></script>
<script>
    // Initialize chart after scripts are loaded
    if (document.getElementById('orderChart')) {
        loadOrderChart('monthly');
    }
</script>
}
