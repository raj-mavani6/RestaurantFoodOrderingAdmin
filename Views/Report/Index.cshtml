@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h2>
                <i class="fas fa-chart-bar me-2"></i>Reports & Analytics
            </h2>
            <p class="text-muted">Comprehensive business reports and analytics dashboard</p>
        </div>
    </div>

    <!-- Report Cards -->
    <div class="row">
        <!-- Sales Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-dollar-sign fa-3x text-success"></i>
                    </div>
                    <h4>Sales Reports</h4>
                    <p class="text-muted mb-3">View detailed sales analysis and revenue trends</p>
                    <a href="@Url.Action("Sales")" class="btn btn-success">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Order Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-receipt fa-3x text-primary"></i>
                    </div>
                    <h4>Order Reports</h4>
                    <p class="text-muted mb-3">Track orders by status and performance</p>
                    <a href="@Url.Action("Orders")" class="btn btn-primary">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Customer Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-users fa-3x text-info"></i>
                    </div>
                    <h4>Customer Reports</h4>
                    <p class="text-muted mb-3">Customer analytics and behavior insights</p>
                    <a href="@Url.Action("Customers")" class="btn btn-info">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Food Item Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-utensils fa-3x text-warning"></i>
                    </div>
                    <h4>Food Item Reports</h4>
                    <p class="text-muted mb-3">Menu performance and popularity analysis</p>
                    <a href="@Url.Action("FoodItems")" class="btn btn-warning">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Revenue Reports -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-chart-line fa-3x text-danger"></i>
                    </div>
                    <h4>Revenue Reports</h4>
                    <p class="text-muted mb-3">Revenue analysis by time period</p>
                    <a href="@Url.Action("Revenue")" class="btn btn-danger">
                        <i class="fas fa-eye me-1"></i>View Report
                    </a>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card report-card h-100">
                <div class="card-body text-center">
                    <div class="report-icon mb-3">
                        <i class="fas fa-tachometer-alt fa-3x text-secondary"></i>
                    </div>
                    <h4>Quick Stats</h4>
                    <p class="text-muted mb-3">Real-time business metrics overview</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                        <i class="fas fa-eye me-1"></i>View Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Options -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-download me-2"></i>Export Options
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">Export reports to CSV for external analysis</p>
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportSalesCSV")" class="btn btn-outline-success w-100">
                                <i class="fas fa-file-csv me-1"></i>Sales CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportOrdersCSV")" class="btn btn-outline-primary w-100">
                                <i class="fas fa-file-csv me-1"></i>Orders CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportCustomersCSV")" class="btn btn-outline-info w-100">
                                <i class="fas fa-file-csv me-1"></i>Customers CSV
                            </a>
                        </div>
                        <div class="col-md-3 mb-2">
                            <a href="@Url.Action("ExportFoodItemsCSV")" class="btn btn-outline-warning w-100">
                                <i class="fas fa-file-csv me-1"></i>Food Items CSV
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .report-card {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        }

    .report-icon {
        opacity: 0.8;
    }
</style>
