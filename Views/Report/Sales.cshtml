@model List<RestaurantFoodOrderingAdmin.Models.Order>
@{
    ViewData["Title"] = "Sales Reports";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-dollar-sign me-2"></i>Sales Reports
                    </h2>
                    <p class="text-muted">Detailed sales analysis and revenue trends</p>
                </div>
                <div>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>Back to Reports
                    </a>
                    <a href="@Url.Action("ExportSalesCSV", new { startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })" class="btn btn-success">
                        <i class="fas fa-download me-1"></i>Export CSV
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Date Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate">
                </div>
                <div class="col-md-4">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate">
                </div>
                <div class="col-md-4">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i>Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Orders</h6>
                    <h3 class="mb-0">@ViewBag.TotalOrders</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Revenue</h6>
                    <h3 class="mb-0">₹@ViewBag.TotalRevenue.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6 class="card-title">Total Discount</h6>
                    <h3 class="mb-0">₹@ViewBag.TotalDiscount.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Net Revenue</h6>
                    <h3 class="mb-0">₹@ViewBag.NetRevenue.ToString("N2")</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card chart-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Sales Trend</h5>
                    <div class="chart-filters">
                        <button class="filter-btn" data-filter="daily" onclick="loadSalesChart('daily')">Daily</button>
                        <button class="filter-btn" data-filter="weekly" onclick="loadSalesChart('weekly')">Weekly</button>
                        <button class="filter-btn active" data-filter="monthly" onclick="loadSalesChart('monthly')">Monthly</button>
                        <button class="filter-btn" data-filter="yearly" onclick="loadSalesChart('yearly')">Yearly</button>
                        <button class="filter-btn" data-filter="all" onclick="loadSalesChart('all')">All Time</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="position: relative; height: 350px;">
                        <canvas id="salesChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales Data Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Sales Details</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Items</th>
                                <th>Total Amount</th>
                                <th>Discount</th>
                                <th>Net Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                var netAmount = order.TotalAmount - (order.DiscountAmount ?? 0);
                                <tr>
                                    <td><strong>#@order.OrderId</strong></td>
                                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                                    <td>@(order.Customer?.FullName ?? "N/A")</td>
                                    <td>@(order.OrderItems?.Count ?? 0)</td>
                                    <td>₹@order.TotalAmount.ToString("F2")</td>
                                    <td class="text-danger">-₹@((order.DiscountAmount ?? 0).ToString("F2"))</td>
                                    <td class="text-success"><strong>₹@netAmount.ToString("F2")</strong></td>
                                    <td>
                                        @if (order.Status == "Delivered")
                                        {
                                            <span class="badge bg-success">@order.Status</span>
                                        }
                                        else if (order.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">@order.Status</span>
                                        }
                                        else if (order.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">@order.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@order.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="4" class="text-end">Totals:</th>
                                <th>₹@Model.Sum(o => o.TotalAmount).ToString("F2")</th>
                                <th class="text-danger">-₹@Model.Sum(o => o.DiscountAmount ?? 0).ToString("F2")</th>
                                <th class="text-success">₹@Model.Sum(o => o.TotalAmount - (o.DiscountAmount ?? 0)).ToString("F2")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No sales data found for the selected period.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/js/chart.js"></script>
<script>
    // Initialize chart after scripts are loaded
    if (document.getElementById('salesChart')) {
        loadSalesChart('monthly');
    }
</script>
}

