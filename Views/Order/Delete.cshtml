@model RestaurantFoodOrderingAdmin.Models.Order
@{
    ViewData["Title"] = "Delete Order";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>Delete Order
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Orders
        </a>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-danger">
        <h5 class="alert-heading">
            <i class="fas fa-exclamation-circle me-2"></i>Warning!
        </h5>
        <p class="mb-0">Are you sure you want to delete this order? This action cannot be undone.</p>
    </div>

    <!-- Order Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Order to be Deleted</h5>
                </div>
                <div class="card-body">

                <dl class="row">
                    <dt class="col-sm-4">Order ID:</dt>
                    <dd class="col-sm-8">#@Model.OrderId</dd>

                    <dt class="col-sm-4">Customer:</dt>
                    <dd class="col-sm-8">@Model.Customer?.FullName</dd>

                    <dt class="col-sm-4">Total Amount:</dt>
                    <dd class="col-sm-8">₹@Model.TotalAmount</dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge bg-pending">@Model.Status</span>
                        }
                        else if (Model.Status == "Confirmed")
                        {
                            <span class="badge bg-confirmed">@Model.Status</span>
                        }
                        else if (Model.Status == "Preparing")
                        {
                            <span class="badge bg-preparing">@Model.Status</span>
                        }
                        else if (Model.Status == "Delivered")
                        {
                            <span class="badge bg-delivered">@Model.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-cancelled">@Model.Status</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Order Date:</dt>
                    <dd class="col-sm-8">@Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")</dd>

                    <dt class="col-sm-4">Delivery Address:</dt>
                    <dd class="col-sm-8">@Model.DeliveryAddress</dd>
                </dl>

                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Form -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card mt-4 border-danger">
                <div class="card-body">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="OrderId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete This Order
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>No, Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
