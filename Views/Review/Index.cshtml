@model IEnumerable<RestaurantFoodOrderingAdmin.Models.Review>
@{
    ViewData["Title"] = "Reviews Management";
}

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-md-2">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-star"></i>
            </div>
            <div class="stat-details">
                <h6>Total Reviews</h6>
                <h3>@ViewBag.TotalReviews</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="stat-details">
                <h6>Average Rating</h6>
                <h3>@ViewBag.AverageRating.ToString("F1")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-light">
            <div class="text-center">
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <h6 class="mt-2">5 Stars</h6>
                <h4>@ViewBag.FiveStarCount</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-light">
            <div class="text-center">
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="far fa-star text-muted"></i>
                <h6 class="mt-2">4 Stars</h6>
                <h4>@ViewBag.FourStarCount</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-light">
            <div class="text-center">
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="fas fa-star text-warning"></i>
                <i class="far fa-star text-muted"></i>
                <i class="far fa-star text-muted"></i>
                <h6 class="mt-2">3 Stars</h6>
                <h4>@ViewBag.ThreeStarCount</h4>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="stat-card bg-light">
            <div class="text-center">
                <i class="fas fa-star text-danger"></i>
                <i class="fas fa-star text-danger"></i>
                <i class="far fa-star text-muted"></i>
                <i class="far fa-star text-muted"></i>
                <i class="far fa-star text-muted"></i>
                <h6 class="mt-2">1-2 Stars</h6>
                <h4>@(ViewBag.TwoStarCount + ViewBag.OneStarCount)</h4>
            </div>
        </div>
    </div>
</div>

<!-- Filter and Search Section -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filters & Search</h5>
        <button class="btn btn-sm btn-danger" onclick="deleteSelected()">
            <i class="fas fa-trash me-1"></i>Delete Selected
        </button>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Search</label>
                        <input type="text" name="searchTerm" class="form-control"
                               value="@ViewBag.SearchTerm" placeholder="Search by customer, food, or comment...">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Filter by Rating</label>
                        <select name="rating" class="form-select">
                            <option value="">All Ratings</option>
                            <option value="5" selected="@(ViewBag.SelectedRating == 5)">5 Stars</option>
                            <option value="4" selected="@(ViewBag.SelectedRating == 4)">4 Stars</option>
                            <option value="3" selected="@(ViewBag.SelectedRating == 3)">3 Stars</option>
                            <option value="2" selected="@(ViewBag.SelectedRating == 2)">2 Stars</option>
                            <option value="1" selected="@(ViewBag.SelectedRating == 1)">1 Star</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select">
                            <option value="">All Status</option>
                            <option value="approved" selected="@(ViewBag.SelectedStatus == "approved")">Approved</option>
                            <option value="hidden" selected="@(ViewBag.SelectedStatus == "hidden")">Hidden</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Sort By</label>
                        <select name="sortBy" class="form-select">
                            <option value="date_desc" selected="@(ViewBag.SortBy == "date_desc")">Newest First</option>
                            <option value="date_asc" selected="@(ViewBag.SortBy == "date_asc")">Oldest First</option>
                            <option value="rating_desc" selected="@(ViewBag.SortBy == "rating_desc")">Highest Rating</option>
                            <option value="rating_asc" selected="@(ViewBag.SortBy == "rating_asc")">Lowest Rating</option>
                            <option value="customer" selected="@(ViewBag.SortBy == "customer")">Customer Name</option>
                            <option value="food" selected="@(ViewBag.SortBy == "food")">Food Name</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i>Apply
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Reviews Table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-comments me-2"></i>All Reviews (@Model.Count())</h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th width="50">
                                <input type="checkbox" id="selectAll" onclick="toggleSelectAll()">
                            </th>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Food Item</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th width="150">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model)
                        {
                            <tr id="review-@review.ReviewId">
                                <td>
                                    <input type="checkbox" class="review-checkbox" value="@review.ReviewId">
                                </td>
                                <td>@review.ReviewId</td>
                                <td>
                                    <strong>@review.Customer?.FullName</strong><br>
                                    <small class="text-muted">@review.Customer?.Email</small>
                                </td>
                                <td>
                                    <strong>@review.FoodItem?.FoodName</strong><br>
                                    <small class="text-muted">@review.FoodItem?.Category?.CategoryName</small>
                                </td>
                                <td>
                                    <div class="rating-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <i class="fas fa-star text-warning"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star text-muted"></i>
                                            }
                                        }
                                    </div>
                                    <small class="text-muted">(@review.Rating/5)</small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <span class="review-comment">
                                            @(review.Comment.Length > 100 ? review.Comment.Substring(0, 100) + "..." : review.Comment)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No comment</span>
                                    }
                                </td>
                                <td>
                                    <small>@review.ReviewDate.ToString("dd MMM yyyy")</small><br>
                                    <small class="text-muted">@review.ReviewDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    @if (review.IsApproved)
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Hidden</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-warning" onclick="toggleApproval(@review.ReviewId)"
                                            title="Toggle Approval">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteReview(@review.ReviewId)"
                                            title="Delete Review">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-star fa-4x text-muted mb-3"></i>
                <h4>No Reviews Found</h4>
                <p class="text-muted">There are no reviews to display.</p>
            </div>
        }
    </div>
</div>

<style>
    .stat-card {
        background: white;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 10px;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .stat-details h6 {
        margin: 0;
        font-size: 0.85rem;
        color: #666;
    }

    .stat-details h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: bold;
    }

    .rating-stars {
        font-size: 1.1rem;
    }

    .review-comment {
        font-style: italic;
        color: #555;
    }
</style>

<script>
    function toggleSelectAll() {
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.review-checkbox');
        checkboxes.forEach(cb => cb.checked = selectAll.checked);
    }

    function deleteReview(id) {
        if (confirm('Are you sure you want to delete this review?')) {
            fetch('/Review/Delete/' + id, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    document.getElementById('review-' + id).remove();
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to delete review');
            });
        }
    }

    function toggleApproval(id) {
        fetch('/Review/ToggleApproval/' + id, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert(data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to update review status');
        });
    }

    function deleteSelected() {
        const checkboxes = document.querySelectorAll('.review-checkbox:checked');
        if (checkboxes.length === 0) {
            alert('Please select at least one review to delete');
            return;
        }

        if (confirm(`Are you sure you want to delete ${checkboxes.length} review(s)?`)) {
            const ids = Array.from(checkboxes).map(cb => cb.value).join(',');

            fetch('/Review/DeleteMultiple', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: 'ids=' + encodeURIComponent(ids)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert(data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to delete reviews');
            });
        }
    }
</script>
