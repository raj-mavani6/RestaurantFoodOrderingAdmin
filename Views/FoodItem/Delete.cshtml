@model RestaurantFoodOrderingAdmin.Models.FoodItem
@{
    ViewData["Title"] = "Delete Food Item";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>Delete Food Item
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <!-- Warning Alert -->
    <div class="alert alert-danger">
        <h5 class="alert-heading">
            <i class="fas fa-exclamation-circle me-2"></i>Warning!
        </h5>
        <p class="mb-0">Are you sure you want to delete this food item? This action cannot be undone.</p>
    </div>

    <!-- Food Item Details Card -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Food Item to be Deleted</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="text-center mb-3">
                            <img src="@Model.ImageUrl" alt="@Model.FoodName" class="img-fluid rounded" style="max-height: 200px;">
                        </div>
                    }

                <dl class="row">
                    <dt class="col-sm-4">Food ID:</dt>
                    <dd class="col-sm-8">@Model.FoodId</dd>

                    <dt class="col-sm-4">Food Name:</dt>
                    <dd class="col-sm-8">@Model.FoodName</dd>

                    <dt class="col-sm-4">Description:</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Category:</dt>
                    <dd class="col-sm-8">@Model.Category?.CategoryName</dd>

                    <dt class="col-sm-4">Price:</dt>
                    <dd class="col-sm-8">₹@Model.Price</dd>

                    <dt class="col-sm-4">Type:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsVeg)
                        {
                            <span class="badge bg-success">Vegetarian</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Non-Vegetarian</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Unavailable</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created Date:</dt>
                    <dd class="col-sm-8">@Model.CreatedDate.ToString("dd MMM yyyy")</dd>
                </dl>

                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Form -->
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card mt-4 border-danger">
                <div class="card-body">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="FoodId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-2"></i>Yes, Delete This Food Item
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>No, Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
